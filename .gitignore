# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Virtual environments ---
.venv/
venv/
env/

# --- Environment variables / secrets ---
.env
.env.*
!.env.example
*.json
!package*.json
gha-creds-*.json

# --- ChromaDB local data (FAQ vector store - rebuilt automatically on
# first startup if missing, never commit the binary index files) ---
chroma_db/
backend/chroma_db/

# --- uv ---
# (uv.lock SHOULD be committed for reproducible installs - not ignored)

# --- IDE / editor ---
.vscode/
.idea/
*.swp

# --- OS ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log

# --- Build artifacts ---
*.zip
dist/
build/
*.egg-info/

# --- Streamlit ---
.streamlit/secrets.toml

# --- Temp files dropped by face registration (auth/routes.py cleans
# these up itself, but ignore them as a safety net) ---
temp_*

# Next.js
frontend-next/node_modules/
frontend-next/.next/
node_modules/
.next/
